session_start();
 
// variables de sesion disponibles en todas las paginas
$loggedIn  = isset($_SESSION['user_id']);
$username  = $loggedIn ? htmlspecialchars($_SESSION['username'])  : '';
$fullName  = $loggedIn ? htmlspecialchars($_SESSION['full_name']) : '';
$userId    = $loggedIn ? (int)$_SESSION['user_id'] : 0;


